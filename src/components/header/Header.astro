---
import HamburgerButton from "./_components/HamburgerButton/HamburgerButton.astro";
import NavMenu from "./_components/NavMenu/NavMenu.astro";
import "./header.css";
import MobileNav from "./_components/NavMenu/MobileNav.astro";
import Button from "@stateless/Button.astro";
const img = "/images/sofilogo.png";
const url = Astro.url;
---

<script  is:inline>
  import { HamburgerButton } from "./HamburgerButton/hamburger.ts";
</script>


<header class="header">
    <a href="/"><img class="header__logo" src={img} alt="Logo image" width="50px" height="50" /></a>
    <NavMenu />
    {
      url.pathname !== "/access" && (
        <Button id="login-button" class="login-button" href="/access">
          Acceder
        </Button>
      )
    }
    <HamburgerButton/>
    <MobileNav />
</header>
